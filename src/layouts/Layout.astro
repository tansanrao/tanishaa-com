---
import SiteFooter from '../components/site/SiteFooter.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import '../styles/global.css';

interface Props {
  pageTitle?: string;
  activeNav?: 'work' | 'contact';
}

const { pageTitle = 'Tanishaa Rao — Portfolio', activeNav } = Astro.props;
const pathname = Astro.url.pathname;
const resolvedActiveNav = activeNav ?? (pathname.startsWith('/work') ? 'work' : pathname.startsWith('/contact') ? 'contact' : undefined);
---

<!doctype html>
<html lang="en" class="bg-paper text-ink">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen bg-paper text-ink antialiased">
    <div class="flex min-h-screen flex-col bg-paper text-ink">
      <SiteHeader active={resolvedActiveNav} />
      <main id="content" class="flex-1">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
