---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import HeroMediaPlaceholder from '../components/HeroMediaPlaceholder.astro';
import BioBlock from '../components/BioBlock.astro';
import FooterBand from '../components/FooterBand.astro';
---

<Layout pageTitle="Tanishaa Rao — Home">
  <main class="min-h-screen flex flex-col bg-paper text-ink">
    <NavBar />
    <div class="flex-1 w-full flex flex-col">
      <div class="flex-[2] flex items-center justify-center">
        <HeroMediaPlaceholder />
      </div>
      <div class="flex-[1] flex items-center justify-center pb-8">
        <BioBlock />
      </div>
    </div>
    <FooterBand />
  </main>
</Layout>
