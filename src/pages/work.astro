---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import FooterBand from '../components/FooterBand.astro';
---

<Layout>
  <main class="min-h-screen flex flex-col items-center bg-paper text-ink">
    <NavBar />
    <section class="flex-1 w-full max-w-4xl px-6 mt-16 text-center">
      <h1 class="text-sm uppercase tracking-[0.1em]">Work</h1>
      <p class="mt-6 text-[11px] leading-relaxed">
        Portfolio pieces coming soon. For now, return to the landing page to view the core profile.
      </p>
    </section>
    <FooterBand />
  </main>
</Layout>

