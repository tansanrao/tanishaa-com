---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import FooterBand from '../components/FooterBand.astro';
import WorkIndexItem from '../components/work/WorkIndexItem.astro';
import { workProjects } from '../data/work';

const projects = [...workProjects].sort((a, b) => a.order - b.order);
---

<Layout pageTitle="Tanishaa Rao — Work">
  <main class="min-h-screen bg-paper text-ink">
    <NavBar active="work" />

    <section class="mx-auto mt-[4.5rem] w-full max-w-[1280px] px-8 pb-24">
      <div class="space-y-[5.5rem]">
        {projects.map((project) => (
          <WorkIndexItem
            href={`/work/${project.slug}`}
            title={project.title}
            medium={project.medium}
            publication={project.publication}
            summary={project.indexSummary}
            cover={{ src: project.coverImage, alt: `${project.title} cover image` }}
          />
        ))}
      </div>
    </section>

    <FooterBand />
  </main>
</Layout>
