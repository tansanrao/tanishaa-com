---
import Layout from '../layouts/Layout.astro';
---

<Layout pageTitle="Tanishaa Rao — Contact" activeNav="contact">
  <section class="mx-auto flex min-h-[calc(100vh-10.5rem)] w-full items-center justify-center px-6 py-16">
    <div class="flex w-full max-w-[30rem] flex-col items-center border border-ink/20 px-6 py-8 sm:px-10 sm:py-10">
      <h1 class="text-center text-sm uppercase tracking-[0.1em]">Contact</h1>
      <p class="body-copy-justify body-copy-hero mt-6 text-[11px] leading-relaxed">
        If you’d like more information, want to collaborate, say hello, or are
        interested in purchasing work (money is nice, but I’m also open to
        barter: lessons, objects, or secret family recipes, everything is fair game),
        please feel free to reach out.
      </p>
      <div class="mx-auto mt-10 flex w-full max-w-xl flex-col items-center gap-4 text-[11px] uppercase tracking-[0.08em] sm:flex-row sm:justify-center sm:gap-8">
        <a class="transition-colors hover:text-accent focus-visible-outline" href="mailto:2003tanishaa@gmail.com">Email</a>
        <a class="transition-colors hover:text-accent focus-visible-outline" href="/resume_tanishaarao.pdf" target="_blank" rel="noreferrer">Resume</a>
        <a class="transition-colors hover:text-accent focus-visible-outline" href="https://www.are.na/tanishaa-rao/channels" target="_blank" rel="noreferrer">Are.na</a>
        <a class="transition-colors hover:text-accent focus-visible-outline" href="http://linkedin.com/in/tanishaarao" target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
  </section>
</Layout>
