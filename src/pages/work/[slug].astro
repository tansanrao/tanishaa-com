---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import FooterBand from '../../components/FooterBand.astro';
import ProjectGallery from '../../components/work/ProjectGallery.astro';
import ProcessGallery from '../../components/work/ProcessGallery.astro';
import ProjectMeta from '../../components/work/ProjectMeta.astro';
import { getWorkProjects, type WorkProject } from '../../lib/work';

export async function getStaticPaths() {
  const projects = await getWorkProjects();

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props as { project: WorkProject };
const processGallery = project.processGallery.length ? project.processGallery : project.mainGallery.slice(1, 5);
---

<Layout pageTitle={`Tanishaa Rao — ${project.title}`}>
  <main class="min-h-screen bg-paper text-ink">
    <NavBar active="work" />

    <section class="mx-auto mt-10 w-full max-w-[1280px] px-6 pb-24 sm:px-8 lg:pb-28">
      <div class="mb-8 lg:mb-10">
        <a href="/work" class="focus-visible-outline font-accent text-[12px] uppercase tracking-[0.18em] text-ink/60 transition hover:text-accent">
          Back to Work
        </a>
      </div>

      <div class="lg:grid lg:grid-cols-12 lg:gap-x-8 xl:gap-x-10">
        <h1 class="text-[clamp(2.6rem,7vw,5.4rem)] font-semibold leading-[0.92] tracking-[-0.065em] lg:col-span-12">
          {project.title}
        </h1>

        <div class="mt-9 lg:col-span-8">
          <ProjectGallery gallery={project.mainGallery} title={project.title} />
        </div>

        <div class="mt-7 lg:col-span-8">
          <ProjectMeta
            title={project.title}
            year={project.year}
            medium={project.medium}
            publication={project.publication}
            summary={project.detailSummary}
          />
        </div>

        {project.overviewHtml && (
          <section class="mt-12 lg:col-span-8">
            <div class="rich-copy text-[14px] leading-[1.75] text-ink/82" set:html={project.overviewHtml} />
          </section>
        )}

        <section class="work-process-section mt-24 lg:col-span-12">
          <div class="work-process-heading-row">
            <h2 class="work-process-heading text-[clamp(2rem,5vw,3.2rem)] font-semibold leading-none tracking-[-0.05em]">
              Process
            </h2>
          </div>

          <div class="work-process-copy">
            {project.processHtml ? (
              <div class="rich-copy text-[14px] leading-[1.75] text-ink/82" set:html={project.processHtml} />
            ) : (
              <p class="text-[14px] leading-[1.7] text-ink/72">Process documentation is being organized for this project.</p>
            )}
          </div>

          <div class="work-process-gallery-wrap">
            <ProcessGallery gallery={processGallery} title={project.title} />
          </div>
        </section>
      </div>
    </section>

    <FooterBand />
  </main>
</Layout>
