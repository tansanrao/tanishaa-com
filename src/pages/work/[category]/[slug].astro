---
import Layout from '../../../layouts/Layout.astro';
import ProjectDetail from '../../../components/work/ProjectDetail.astro';
import { getWorkProjects, type WorkProject } from '../../../lib/work';

export async function getStaticPaths() {
  const projects = await getWorkProjects();

  return projects.map((project) => ({
    params: { category: project.category, slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props as { project: WorkProject };
---

<Layout pageTitle={`Tanishaa Rao — ${project.title}`} activeNav="work">
  <ProjectDetail project={project} />
</Layout>
