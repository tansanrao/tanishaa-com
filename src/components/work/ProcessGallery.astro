---
import MediaGallery from './MediaGallery.astro';

interface GalleryItem {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  gallery: GalleryItem[];
  title: string;
}

const { gallery, title } = Astro.props;
---

<MediaGallery
  gallery={gallery}
  title={`${title} process`}
  layout="stack"
  itemAspect="4 / 3"
  showInlineCaption={false}
  showInlineControls={false}
  showFullscreenButton={false}
/>
