---
import type { WorkMedia } from '../../lib/work';
import MediaGallery from './MediaGallery.astro';

interface Props {
  gallery: WorkMedia[];
  title: string;
}

const { gallery, title } = Astro.props as Props;
---

<MediaGallery
  gallery={gallery}
  title={`${title} process`}
  layout="stack"
  itemAspect="4 / 3"
  showInlineCaption={false}
  showInlineControls={false}
  showFullscreenButton={false}
/>
