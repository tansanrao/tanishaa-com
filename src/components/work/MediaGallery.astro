---
import { Image, Picture } from 'astro:assets';
import type { WorkMedia } from '../../lib/work';

interface Props {
  gallery: WorkMedia[];
  title: string;
  layout?: 'filmstrip' | 'stack';
  stageAspect?: string;
  thumbAspect?: string;
  itemAspect?: string;
  showInlineCaption?: boolean;
  showInlineControls?: boolean;
  showFullscreenButton?: boolean;
}

const {
  gallery,
  title,
  layout = 'filmstrip',
  stageAspect = '3 / 2',
  thumbAspect = stageAspect,
  itemAspect = '4 / 3',
  showInlineCaption = layout === 'filmstrip',
  showInlineControls = layout === 'filmstrip',
  showFullscreenButton = layout === 'filmstrip',
} = Astro.props as Props;

const hasMultipleItems = gallery.length > 1;
const isFilmstrip = layout === 'filmstrip';
const viewerItems = gallery.map((item) => ({
  type: item.type,
  src: item.viewerSrc,
  posterSrc: item.type === 'video' ? item.poster?.src : undefined,
  alt: item.alt,
  caption: item.caption,
  width: item.viewerWidth,
  height: item.viewerHeight,
}));
const getResponsiveWidths = (maxWidth: number, candidates: number[]) => {
  const widths = [...new Set(candidates.filter((width) => width < maxWidth).concat(maxWidth))];
  return widths.sort((left, right) => left - right);
};
---

<section
  class:list={[
    isFilmstrip ? 'project-gallery grid gap-4 lg:grid-cols-[minmax(0,1fr)_12rem]' : 'process-gallery grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-1',
  ]}
  style={`--gallery-stage-aspect:${stageAspect}; --gallery-thumb-aspect:${thumbAspect}; --gallery-item-aspect:${itemAspect};`}
  data-media-gallery
>
  <script is:inline type="application/json" data-gallery-items set:html={JSON.stringify(viewerItems)} />

  {isFilmstrip ? (
    <>
      <div class="min-w-0">
        <div class="project-gallery-stage relative overflow-hidden">
          {gallery.map((item, index) => (
            <div
              class:list={[
                'project-gallery-slide h-full w-full',
                index === 0 ? 'block' : 'hidden',
              ]}
              data-gallery-slide
              data-index={index}
            >
              {item.type === 'image' ? (
                <button
                  type="button"
                  class="project-gallery-inline-trigger flex h-full w-full cursor-zoom-in items-center justify-center p-0 text-left"
                  data-gallery-open
                  aria-label={`Open ${title} image ${index + 1} in fullscreen`}
                >
                  <Picture
                    src={item.image}
                    alt={item.alt}
                    formats={['avif', 'webp']}
                    width={Math.min(item.image.width, 1400)}
                    widths={getResponsiveWidths(Math.min(item.image.width, 1400), [480, 960])}
                    sizes="(min-width: 1024px) 900px, 100vw"
                    layout="constrained"
                    quality="high"
                    fit="contain"
                    position="center"
                    priority={index === 0}
                    class="h-full w-full object-contain"
                    pictureAttributes={{ class: 'h-full w-full' }}
                  />
                </button>
              ) : (
                <video
                  class="h-full w-full bg-black object-contain"
                  src={item.src}
                  poster={item.poster?.src}
                  controls
                  preload="metadata"
                  playsinline
                  data-gallery-video
                  aria-label={item.alt}
                />
              )}
            </div>
          ))}

          {hasMultipleItems && showInlineControls && (
            <div class="pointer-events-none absolute inset-y-0 left-0 right-0 flex items-center justify-between px-4 sm:px-5">
              <button
                type="button"
                class="viewer-icon-button pointer-events-auto"
                data-gallery-prev
                aria-label="Previous media item"
              >
                <span aria-hidden="true" class="text-2xl leading-none">‹</span>
              </button>
              <button
                type="button"
                class="viewer-icon-button pointer-events-auto"
                data-gallery-next
                aria-label="Next media item"
              >
                <span aria-hidden="true" class="text-2xl leading-none">›</span>
              </button>
            </div>
          )}

          {showFullscreenButton && (
            <div class="absolute bottom-3 right-3 z-10">
              <button
                type="button"
                class="viewer-icon-button viewer-icon-button-compact"
                data-gallery-open
                aria-label={`Open ${title} gallery in fullscreen`}
              >
                <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M8 3H3v5" />
                  <path d="M16 3h5v5" />
                  <path d="M21 16v5h-5" />
                  <path d="M8 21H3v-5" />
                </svg>
              </button>
            </div>
          )}
        </div>
      </div>

      {hasMultipleItems && (
        <div
          class="project-gallery-filmstrip order-3 border border-ink/12 bg-paper/55 lg:order-none"
          data-gallery-filmstrip
          aria-label={`${title} media thumbnails`}
        >
          <div class="project-gallery-filmstrip-inner flex gap-3 p-3 lg:flex-col" data-gallery-filmstrip-scroll>
            {gallery.map((item, index) => (
              <button
                type="button"
                class:list={[
                  'project-gallery-thumb focus-visible-outline relative overflow-hidden transition',
                  index === 0 ? 'is-active' : '',
                ]}
                data-gallery-thumb
                data-index={index}
                aria-label={`View media item ${index + 1} for ${title}`}
                aria-pressed={index === 0 ? 'true' : 'false'}
              >
                {item.type === 'image' ? (
                  <Image
                    class="h-full w-full object-cover object-center"
                    src={item.image}
                    alt=""
                    width={192}
                    height={128}
                    quality="mid"
                    fit="cover"
                    position="center"
                    loading="lazy"
                  />
                ) : item.poster ? (
                  <>
                    <Image
                      class="h-full w-full object-cover object-center"
                      src={item.poster}
                      alt=""
                      width={192}
                      height={128}
                      quality="mid"
                      fit="cover"
                      position="center"
                      loading="lazy"
                    />
                    <span class="media-thumb-play" aria-hidden="true">▶</span>
                  </>
                ) : (
                  <span class="flex h-full w-full items-center justify-center bg-black text-paper">
                    <span class="media-thumb-play media-thumb-play-static" aria-hidden="true">▶</span>
                  </span>
                )}
              </button>
            ))}
          </div>
        </div>
      )}

      {showInlineCaption && (
        <div class="project-gallery-caption order-2 min-h-[20px] text-[12px] uppercase tracking-[0.12em] text-ink/60 lg:order-none" data-gallery-caption>
          {gallery[0]?.caption ?? gallery[0]?.alt}
        </div>
      )}
    </>
  ) : (
    <>
      {gallery.map((item, index) => (
        item.type === 'image' && (
          <button
            type="button"
            class="process-gallery-card focus-visible-outline overflow-hidden transition"
            data-gallery-item-button
            data-index={index}
            aria-label={`Open ${title} image ${index + 1} in fullscreen`}
          >
            <Picture
              src={item.image}
              alt={item.alt}
              formats={['avif', 'webp']}
              width={Math.min(item.image.width, 640)}
              widths={getResponsiveWidths(Math.min(item.image.width, 640), [320])}
              sizes="(min-width: 1024px) 100vw, (min-width: 640px) 33vw, 50vw"
              layout="constrained"
              quality="high"
              fit="cover"
              position="center"
              class="h-full w-full object-cover object-center"
              pictureAttributes={{ class: 'h-full w-full' }}
              loading="lazy"
            />
          </button>
        )
      ))}
    </>
  )}

  <div class="fixed inset-0 z-[80] hidden items-center justify-center bg-black/88 px-4 py-6 sm:px-8 sm:py-8" data-viewer-overlay>
    <button type="button" class="absolute inset-0" data-viewer-close aria-label="Close fullscreen viewer"></button>

    <div class="relative z-10 flex max-h-full w-full flex-col items-center justify-center gap-5">
      <div class="flex w-full max-w-[1400px] items-center justify-between gap-8">
        <div class="font-accent text-[12px] uppercase tracking-[0.16em] text-paper/70" data-viewer-counter></div>
        <button type="button" class="viewer-icon-button" data-viewer-dismiss aria-label="Close viewer">
          <span aria-hidden="true" class="text-xl leading-none">×</span>
        </button>
      </div>

      <div class="relative flex w-full max-w-[1400px] items-center justify-center">
        {hasMultipleItems && (
          <button
            type="button"
            class="viewer-icon-button absolute left-2 top-1/2 z-10 -translate-y-1/2 sm:left-6"
            data-viewer-prev
            aria-label="Previous fullscreen media item"
          >
            <span aria-hidden="true" class="text-2xl leading-none">‹</span>
          </button>
        )}

        <div class="viewer-stage viewer-stage-fullscreen">
          <img class="h-full w-full object-contain" data-viewer-image src="" alt="" />
          <video class="hidden h-full w-full object-contain" data-viewer-video controls preload="metadata" playsinline aria-label=""></video>
        </div>

        {hasMultipleItems && (
          <button
            type="button"
            class="viewer-icon-button absolute right-2 top-1/2 z-10 -translate-y-1/2 sm:right-6"
            data-viewer-next
            aria-label="Next fullscreen media item"
          >
            <span aria-hidden="true" class="text-2xl leading-none">›</span>
          </button>
        )}
      </div>

      <div class="min-h-[20px] max-w-[900px] text-center text-[12px] uppercase tracking-[0.12em] text-paper/72" data-viewer-caption></div>
    </div>
  </div>
</section>

<script>
  const initMediaGalleries = () => {
    type ViewerItem = {
      type: 'image' | 'video';
      src: string;
      posterSrc?: string;
      alt: string;
      caption?: string;
      width?: number;
      height?: number;
    };

    const galleries = document.querySelectorAll('[data-media-gallery]');

    galleries.forEach((galleryRoot) => {
      if (!(galleryRoot instanceof HTMLElement) || galleryRoot.dataset.bound === 'true') {
        return;
      }

      galleryRoot.dataset.bound = 'true';

      const itemsNode = galleryRoot.querySelector('[data-gallery-items]');
      const rawItems =
        itemsNode instanceof HTMLScriptElement && itemsNode.textContent
          ? JSON.parse(itemsNode.textContent)
          : [];

      const items = Array.isArray(rawItems)
        ? rawItems.filter(
            (item): item is ViewerItem =>
              typeof item === 'object' &&
              item !== null &&
              (item.type === 'image' || item.type === 'video') &&
              typeof item.src === 'string' &&
              typeof item.alt === 'string'
          )
        : [];

      const slides = Array.from(galleryRoot.querySelectorAll('[data-gallery-slide]'));
      const thumbs = Array.from(galleryRoot.querySelectorAll('[data-gallery-thumb]'));
      const itemButtons = Array.from(galleryRoot.querySelectorAll('[data-gallery-item-button]'));
      const openButtons = Array.from(galleryRoot.querySelectorAll('[data-gallery-open]'));
      const prevButton = galleryRoot.querySelector('[data-gallery-prev]');
      const nextButton = galleryRoot.querySelector('[data-gallery-next]');
      const caption = galleryRoot.querySelector('[data-gallery-caption]');
      const filmstrip = galleryRoot.querySelector('[data-gallery-filmstrip]');
      const filmstripScroll = galleryRoot.querySelector('[data-gallery-filmstrip-scroll]');
      const overlay = galleryRoot.querySelector('[data-viewer-overlay]');
      const viewerImage = galleryRoot.querySelector('[data-viewer-image]');
      const viewerVideo = galleryRoot.querySelector('[data-viewer-video]');
      const viewerCaption = galleryRoot.querySelector('[data-viewer-caption]');
      const viewerCounter = galleryRoot.querySelector('[data-viewer-counter]');
      const viewerPrev = galleryRoot.querySelector('[data-viewer-prev]');
      const viewerNext = galleryRoot.querySelector('[data-viewer-next]');
      const viewerCloseButtons = galleryRoot.querySelectorAll('[data-viewer-close], [data-viewer-dismiss]');

      let activeIndex = 0;

      const wrapIndex = (index: number) => {
        const length = items.length;
        return length ? (index + length) % length : 0;
      };

      const pauseVideo = (video: HTMLVideoElement) => {
        video.pause();
      };

      const pauseInactiveVideos = () => {
        slides.forEach((slide, index) => {
          if (index === activeIndex) {
            return;
          }

          slide.querySelectorAll('video').forEach((video) => {
            if (video instanceof HTMLVideoElement) {
              pauseVideo(video);
            }
          });
        });
      };

      const syncThumbState = () => {
        thumbs.forEach((thumb, index) => {
          const isActive = index === activeIndex;
          thumb.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          thumb.classList.toggle('is-active', isActive);
          thumb.classList.toggle('border-accent', isActive);
          thumb.classList.toggle('border-ink/12', !isActive);

          if (isActive) {
            thumb.scrollIntoView({
              behavior: 'smooth',
              block: 'nearest',
              inline: 'nearest',
            });
          }
        });
      };

      const syncInlineState = () => {
        slides.forEach((slide, index) => {
          slide.classList.toggle('hidden', index !== activeIndex);
          slide.classList.toggle('block', index === activeIndex);
        });

        pauseInactiveVideos();

        const current = items[activeIndex];
        if (caption instanceof HTMLElement && current) {
          caption.textContent = current.caption ?? current.alt ?? '';
        }

        syncThumbState();
      };

      const syncViewerState = () => {
        const current = items[activeIndex];
        if (!current || !(viewerImage instanceof HTMLImageElement) || !(viewerVideo instanceof HTMLVideoElement)) {
          return;
        }

        pauseVideo(viewerVideo);

        if (current.type === 'video') {
          viewerImage.classList.add('hidden');
          viewerVideo.classList.remove('hidden');
          viewerVideo.src = current.src;
          viewerVideo.poster = current.posterSrc ?? '';
          viewerVideo.setAttribute('aria-label', current.alt ?? '');
        } else {
          viewerVideo.classList.add('hidden');
          viewerVideo.removeAttribute('src');
          viewerVideo.load();
          viewerImage.classList.remove('hidden');
          viewerImage.src = current.src;
          viewerImage.alt = current.alt ?? '';

          if (typeof current.width === 'number' && current.width > 0) {
            viewerImage.width = current.width;
          }

          if (typeof current.height === 'number' && current.height > 0) {
            viewerImage.height = current.height;
          }
        }

        if (viewerCaption instanceof HTMLElement) {
          viewerCaption.textContent = current.caption ?? current.alt ?? '';
        }

        if (viewerCounter instanceof HTMLElement) {
          viewerCounter.textContent = `${activeIndex + 1} / ${items.length}`;
        }
      };

      const setActive = (index: number) => {
        if (!items.length) {
          return;
        }

        activeIndex = wrapIndex(index);
        if (slides.length) {
          syncInlineState();
        } else {
          syncThumbState();
        }
        syncViewerState();
      };

      const openViewer = (index = activeIndex) => {
        if (!(overlay instanceof HTMLElement)) {
          return;
        }

        setActive(index);
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        document.body.classList.add('viewer-open');
      };

      const closeViewer = () => {
        if (!(overlay instanceof HTMLElement)) {
          return;
        }

        if (viewerVideo instanceof HTMLVideoElement) {
          pauseVideo(viewerVideo);
        }

        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
        document.body.classList.remove('viewer-open');
      };

      prevButton?.addEventListener('click', (event) => {
        event.stopPropagation();
        setActive(activeIndex - 1);
      });

      nextButton?.addEventListener('click', (event) => {
        event.stopPropagation();
        setActive(activeIndex + 1);
      });

      openButtons.forEach((button) => {
        button.addEventListener('click', () => openViewer());
      });

      thumbs.forEach((thumb, index) => {
        thumb.addEventListener('click', () => setActive(index));
      });

      itemButtons.forEach((button) => {
        const index = Number((button as HTMLElement).dataset.index ?? '0');
        button.addEventListener('click', () => openViewer(index));
      });

      viewerPrev?.addEventListener('click', () => setActive(activeIndex - 1));
      viewerNext?.addEventListener('click', () => setActive(activeIndex + 1));

      viewerCloseButtons.forEach((button) => {
        button.addEventListener('click', closeViewer);
      });

      if (filmstrip instanceof HTMLElement) {
        filmstrip.addEventListener('wheel', (event) => {
          if (window.innerWidth >= 1024 && filmstripScroll instanceof HTMLElement) {
            event.preventDefault();
            filmstripScroll.scrollTop += event.deltaY;
          }
        });
      }

      document.addEventListener('keydown', (event) => {
        if (!(overlay instanceof HTMLElement) || overlay.classList.contains('hidden')) {
          return;
        }

        if (event.key === 'Escape') {
          closeViewer();
        } else if (event.key === 'ArrowLeft') {
          event.preventDefault();
          setActive(activeIndex - 1);
        } else if (event.key === 'ArrowRight') {
          event.preventDefault();
          setActive(activeIndex + 1);
        }
      });

      setActive(0);
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMediaGalleries, { once: true });
  } else {
    initMediaGalleries();
  }
</script>
