---
interface GalleryItem {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  gallery: GalleryItem[];
  title: string;
  layout?: 'filmstrip' | 'stack';
  stageAspect?: string;
  thumbAspect?: string;
  itemAspect?: string;
  showInlineCaption?: boolean;
  showInlineControls?: boolean;
  showFullscreenButton?: boolean;
}

const {
  gallery,
  title,
  layout = 'filmstrip',
  stageAspect = '3 / 2',
  thumbAspect = stageAspect,
  itemAspect = '4 / 3',
  showInlineCaption = layout === 'filmstrip',
  showInlineControls = layout === 'filmstrip',
  showFullscreenButton = layout === 'filmstrip',
} = Astro.props;

const hasMultipleImages = gallery.length > 1;
const isFilmstrip = layout === 'filmstrip';
---

<section
  class:list={[
    isFilmstrip ? 'project-gallery grid gap-4 lg:grid-cols-[minmax(0,1fr)_12rem]' : 'process-gallery grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-1',
  ]}
  style={`--gallery-stage-aspect:${stageAspect}; --gallery-thumb-aspect:${thumbAspect}; --gallery-item-aspect:${itemAspect};`}
  data-media-gallery
>
  <script is:inline type="application/json" data-gallery-items set:html={JSON.stringify(gallery)} />

  {isFilmstrip ? (
    <>
      <div class="space-y-4">
        <div class="project-gallery-stage relative overflow-hidden border border-ink/12 bg-[#0f0f10]">
          <button
            type="button"
            class="project-gallery-inline-trigger absolute inset-0 z-0 flex h-full w-full cursor-zoom-in items-center justify-center p-5 text-left"
            data-gallery-open
            aria-label={`Open ${title} gallery in fullscreen`}
          >
            {gallery.map((item, index) => (
              <img
                class:list={[
                  'project-gallery-slide h-full w-full object-contain',
                  index === 0 ? 'block' : 'hidden',
                ]}
                data-gallery-slide
                data-index={index}
                data-caption={item.caption ?? item.alt}
                src={item.src}
                alt={item.alt}
              />
            ))}
          </button>

          {hasMultipleImages && showInlineControls && (
            <div class="pointer-events-none absolute inset-y-0 left-0 right-0 flex items-center justify-between px-4 sm:px-5">
              <button
                type="button"
                class="viewer-icon-button pointer-events-auto"
                data-gallery-prev
                aria-label="Previous image"
              >
                <span aria-hidden="true" class="text-2xl leading-none">‹</span>
              </button>
              <button
                type="button"
                class="viewer-icon-button pointer-events-auto"
                data-gallery-next
                aria-label="Next image"
              >
                <span aria-hidden="true" class="text-2xl leading-none">›</span>
              </button>
            </div>
          )}

          {showFullscreenButton && (
            <div class="absolute bottom-4 right-4 z-10">
              <button
                type="button"
                class="viewer-icon-button h-11 min-w-11 px-4 text-[11px] uppercase tracking-[0.14em]"
                data-gallery-open
                aria-label={`Open ${title} gallery in fullscreen`}
              >
                Fullscreen
              </button>
            </div>
          )}
        </div>

        {showInlineCaption && (
          <div class="min-h-[20px] text-[12px] uppercase tracking-[0.12em] text-ink/60" data-gallery-caption>
            {gallery[0]?.caption ?? gallery[0]?.alt}
          </div>
        )}
      </div>

      {hasMultipleImages && (
        <div
          class="project-gallery-filmstrip border border-ink/10 bg-paper/55"
          data-gallery-filmstrip
          aria-label={`${title} image thumbnails`}
        >
          <div class="project-gallery-filmstrip-inner flex gap-3 p-3 lg:flex-col">
            {gallery.map((item, index) => (
              <button
                type="button"
                class:list={[
                  'project-gallery-thumb focus-visible-outline overflow-hidden border bg-[#d9d9d9] transition',
                  index === 0 ? 'is-active border-accent' : 'border-ink/12 hover:border-ink/30',
                ]}
                data-gallery-thumb
                data-index={index}
                aria-label={`View image ${index + 1} for ${title}`}
                aria-pressed={index === 0 ? 'true' : 'false'}
              >
                <img class="h-full w-full object-cover object-center" src={item.src} alt="" loading="lazy" />
              </button>
            ))}
          </div>
        </div>
      )}
    </>
  ) : (
    <>
      {gallery.map((item, index) => (
        <button
          type="button"
          class="process-gallery-card focus-visible-outline overflow-hidden border border-ink/10 bg-[#ddd6c8] transition hover:border-ink/24"
          data-gallery-item-button
          data-index={index}
          aria-label={`Open ${title} image ${index + 1} in fullscreen`}
        >
          <img
            class="h-full w-full object-cover object-center"
            src={item.src}
            alt={item.alt}
            data-caption={item.caption ?? item.alt}
            loading="lazy"
          />
        </button>
      ))}
    </>
  )}

  <div class="fixed inset-0 z-[80] hidden items-center justify-center bg-black/88 px-4 py-6 sm:px-8 sm:py-8" data-viewer-overlay>
    <button type="button" class="absolute inset-0" data-viewer-close aria-label="Close fullscreen viewer"></button>

    <div class="relative z-10 flex max-h-full w-full flex-col items-center justify-center gap-5">
      <div class="flex w-full max-w-[1400px] items-center justify-between gap-8">
        <div class="font-accent text-[12px] uppercase tracking-[0.16em] text-paper/70" data-viewer-counter></div>
        <button type="button" class="viewer-icon-button" data-viewer-dismiss aria-label="Close viewer">
          <span aria-hidden="true" class="text-xl leading-none">×</span>
        </button>
      </div>

      <div class="relative flex w-full max-w-[1400px] items-center justify-center">
        {hasMultipleImages && (
          <button
            type="button"
            class="viewer-icon-button absolute left-2 top-1/2 z-10 -translate-y-1/2 sm:left-6"
            data-viewer-prev
            aria-label="Previous fullscreen image"
          >
            <span aria-hidden="true" class="text-2xl leading-none">‹</span>
          </button>
        )}

        <div class="viewer-stage viewer-stage-fullscreen">
          <img class="h-full w-full object-contain" data-viewer-image src="" alt="" />
        </div>

        {hasMultipleImages && (
          <button
            type="button"
            class="viewer-icon-button absolute right-2 top-1/2 z-10 -translate-y-1/2 sm:right-6"
            data-viewer-next
            aria-label="Next fullscreen image"
          >
            <span aria-hidden="true" class="text-2xl leading-none">›</span>
          </button>
        )}
      </div>

      <div class="min-h-[20px] max-w-[900px] text-center text-[12px] uppercase tracking-[0.12em] text-paper/72" data-viewer-caption></div>
    </div>
  </div>
</section>

<script>
  const initMediaGalleries = () => {
    type ViewerItem = { src: string; alt: string; caption?: string };

    const galleries = document.querySelectorAll('[data-media-gallery]');

    galleries.forEach((galleryRoot) => {
      if (!(galleryRoot instanceof HTMLElement) || galleryRoot.dataset.bound === 'true') {
        return;
      }

      galleryRoot.dataset.bound = 'true';

      const itemsNode = galleryRoot.querySelector('[data-gallery-items]');
      const rawItems =
        itemsNode instanceof HTMLScriptElement && itemsNode.textContent
          ? JSON.parse(itemsNode.textContent)
          : [];

      const items = Array.isArray(rawItems)
        ? rawItems.filter(
            (item): item is ViewerItem =>
              typeof item === 'object' &&
              item !== null &&
              typeof item.src === 'string' &&
              typeof item.alt === 'string'
          )
        : [];

      const slides = Array.from(galleryRoot.querySelectorAll('[data-gallery-slide]'));
      const thumbs = Array.from(galleryRoot.querySelectorAll('[data-gallery-thumb]'));
      const itemButtons = Array.from(galleryRoot.querySelectorAll('[data-gallery-item-button]'));
      const openButtons = Array.from(galleryRoot.querySelectorAll('[data-gallery-open]'));
      const prevButton = galleryRoot.querySelector('[data-gallery-prev]');
      const nextButton = galleryRoot.querySelector('[data-gallery-next]');
      const caption = galleryRoot.querySelector('[data-gallery-caption]');
      const filmstrip = galleryRoot.querySelector('[data-gallery-filmstrip]');
      const overlay = galleryRoot.querySelector('[data-viewer-overlay]');
      const viewerImage = galleryRoot.querySelector('[data-viewer-image]');
      const viewerCaption = galleryRoot.querySelector('[data-viewer-caption]');
      const viewerCounter = galleryRoot.querySelector('[data-viewer-counter]');
      const viewerPrev = galleryRoot.querySelector('[data-viewer-prev]');
      const viewerNext = galleryRoot.querySelector('[data-viewer-next]');
      const viewerCloseButtons = galleryRoot.querySelectorAll('[data-viewer-close], [data-viewer-dismiss]');

      let activeIndex = 0;

      const wrapIndex = (index: number) => {
        const length = items.length;
        return length ? (index + length) % length : 0;
      };

      const syncThumbState = () => {
        thumbs.forEach((thumb, index) => {
          const isActive = index === activeIndex;
          thumb.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          thumb.classList.toggle('is-active', isActive);
          thumb.classList.toggle('border-accent', isActive);
          thumb.classList.toggle('border-ink/12', !isActive);

          if (isActive) {
            thumb.scrollIntoView({
              behavior: 'smooth',
              block: 'nearest',
              inline: 'nearest',
            });
          }
        });
      };

      const syncInlineState = () => {
        slides.forEach((slide, index) => {
          slide.classList.toggle('hidden', index !== activeIndex);
          slide.classList.toggle('block', index === activeIndex);
        });

        const current = items[activeIndex];
        if (caption instanceof HTMLElement && current) {
          caption.textContent = current.caption ?? current.alt ?? '';
        }

        syncThumbState();
      };

      const syncViewerState = () => {
        const current = items[activeIndex];
        if (!current || !(viewerImage instanceof HTMLImageElement)) {
          return;
        }

        viewerImage.src = current.src;
        viewerImage.alt = current.alt ?? '';

        if (viewerCaption instanceof HTMLElement) {
          viewerCaption.textContent = current.caption ?? current.alt ?? '';
        }

        if (viewerCounter instanceof HTMLElement) {
          viewerCounter.textContent = `${activeIndex + 1} / ${items.length}`;
        }
      };

      const setActive = (index: number) => {
        if (!items.length) {
          return;
        }

        activeIndex = wrapIndex(index);
        if (slides.length) {
          syncInlineState();
        } else {
          syncThumbState();
        }
        syncViewerState();
      };

      const openViewer = (index = activeIndex) => {
        if (!(overlay instanceof HTMLElement)) {
          return;
        }

        setActive(index);
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
        document.body.classList.add('viewer-open');
      };

      const closeViewer = () => {
        if (!(overlay instanceof HTMLElement)) {
          return;
        }

        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
        document.body.classList.remove('viewer-open');
      };

      prevButton?.addEventListener('click', (event) => {
        event.stopPropagation();
        setActive(activeIndex - 1);
      });

      nextButton?.addEventListener('click', (event) => {
        event.stopPropagation();
        setActive(activeIndex + 1);
      });

      openButtons.forEach((button) => {
        button.addEventListener('click', () => openViewer());
      });

      thumbs.forEach((thumb, index) => {
        thumb.addEventListener('click', () => setActive(index));
      });

      itemButtons.forEach((button) => {
        const index = Number((button as HTMLElement).dataset.index ?? '0');
        button.addEventListener('click', () => openViewer(index));
      });

      viewerPrev?.addEventListener('click', () => setActive(activeIndex - 1));
      viewerNext?.addEventListener('click', () => setActive(activeIndex + 1));

      viewerCloseButtons.forEach((button) => {
        button.addEventListener('click', closeViewer);
      });

      if (filmstrip instanceof HTMLElement) {
        filmstrip.addEventListener('wheel', (event) => {
          if (window.innerWidth >= 1024) {
            event.preventDefault();
            filmstrip.scrollTop += event.deltaY;
          }
        });
      }

      document.addEventListener('keydown', (event) => {
        if (!(overlay instanceof HTMLElement) || overlay.classList.contains('hidden')) {
          return;
        }

        if (event.key === 'Escape') {
          closeViewer();
        } else if (event.key === 'ArrowLeft') {
          event.preventDefault();
          setActive(activeIndex - 1);
        } else if (event.key === 'ArrowRight') {
          event.preventDefault();
          setActive(activeIndex + 1);
        }
      });

      setActive(0);
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMediaGalleries, { once: true });
  } else {
    initMediaGalleries();
  }
</script>
