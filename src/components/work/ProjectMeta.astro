---
interface Props {
  title: string;
  year?: string;
  medium?: string;
  publication?: string;
  summary?: string;
}

const { title, year, medium, publication, summary } = Astro.props;
---

<section class="space-y-8">
  <div class="grid gap-4 border-t border-ink/12 pt-5 text-left sm:grid-cols-[minmax(0,1.5fr)_repeat(2,minmax(0,1fr))] sm:gap-6 lg:grid-cols-[minmax(0,1.5fr)_repeat(3,minmax(0,1fr))]">
    <div class="space-y-1">
      <div class="font-accent text-[11px] uppercase tracking-[0.18em] text-ink/48">Project</div>
      <div class="text-[14px] leading-[1.45] text-ink">{title}</div>
    </div>

    {year && (
      <div class="space-y-1">
        <div class="font-accent text-[11px] uppercase tracking-[0.18em] text-ink/48">Year</div>
        <div class="text-[14px] leading-[1.45] text-ink">{year}</div>
      </div>
    )}

    {medium && (
      <div class="space-y-1">
        <div class="font-accent text-[11px] uppercase tracking-[0.18em] text-ink/48">Medium</div>
        <div class="text-[14px] leading-[1.45] text-ink">{medium}</div>
      </div>
    )}

    {publication && (
      <div class="space-y-1">
        <div class="font-accent text-[11px] uppercase tracking-[0.18em] text-ink/48">Client</div>
        <div class="text-[14px] leading-[1.45] text-ink">{publication}</div>
      </div>
    )}
  </div>

  {summary && <p class="max-w-[46ch] text-[16px] leading-[1.58] text-ink/84">{summary}</p>}
</section>
