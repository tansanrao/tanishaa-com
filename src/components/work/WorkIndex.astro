---
import { Image } from 'astro:assets';
import type { WorkCategory, WorkProject } from '../../lib/work';
import WorkTabs from './WorkTabs.astro';

interface Props {
  projects: WorkProject[];
  activeCategory: WorkCategory;
}

interface WorkGridItem {
  title: string;
  href: string;
  image: WorkProject['listingImage'];
  mediumText: string;
  summary: string;
  accessibleLabel: string;
}

const { projects, activeCategory } = Astro.props as Props;

const UNTITLED_PROJECT = 'Untitled Project';
const MEDIUM_PLACEHOLDER = 'Medium TBD';
const SUMMARY_PLACEHOLDER = 'Summary coming soon.';

const normalizeText = (value?: string) => value?.trim() ?? '';

const gridItems: WorkGridItem[] = projects.map((project) => {
  const title = normalizeText(project.title) || UNTITLED_PROJECT;
  const mediumText = normalizeText(project.medium) || MEDIUM_PLACEHOLDER;
  const summary = normalizeText(project.indexSummary) || SUMMARY_PLACEHOLDER;

  return {
    title,
    href: `/work/${project.category}/${project.id}`,
    image: project.listingImage,
    mediumText,
    summary,
    accessibleLabel: `${title}, ${mediumText}`,
  };
});
---

<section class="work-index mx-auto w-full max-w-[1280px] px-6 pb-24 pt-6 font-editorial text-ink sm:px-8 lg:px-10 lg:pt-12">
  <WorkTabs activeCategory={activeCategory} />

  {gridItems.length === 0 && (
    <p class="mx-auto mt-24 max-w-[26rem] text-center font-accent text-[10pt] uppercase tracking-[0.16em] text-ink/52">
      No projects are published here yet.
    </p>
  )}

  {gridItems.length > 0 && (
    <div class="work-grid">
      {gridItems.map((item) => (
        <a
          href={item.href}
          class="work-grid-card focus-visible-outline"
          aria-label={item.accessibleLabel}
        >
          <span class="work-grid-image" aria-hidden="true">
            <Image
              class="h-full w-full object-cover"
              src={item.image.image}
              alt=""
              width="720"
              height="360"
              densities={[1, 2]}
              fit="cover"
              position="center"
              loading="lazy"
            />
          </span>

          <span class="work-grid-copy">
            <span class="work-grid-meta-row">
              <span class="work-grid-medium">{item.mediumText}</span>
              <span class="work-grid-title">{item.title}</span>
            </span>
            <span class="work-grid-summary">{item.summary}</span>
          </span>
        </a>
      ))}
    </div>
  )}
</section>
