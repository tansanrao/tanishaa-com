---
interface MediaItem {
  src: string;
  alt: string;
}

interface Props {
  href: string;
  title: string;
  medium?: string;
  summary?: string;
  cover?: MediaItem;
}

const UNTITLED_PROJECT = 'Untitled Project';
const MEDIUM_PLACEHOLDER = 'Medium TBD';
const SUMMARY_PLACEHOLDER = 'Summary coming soon.';
const COVER_PLACEHOLDER = 'Cover coming soon';

const normalizeText = (value?: string) => value?.trim() ?? '';

const { href, title, medium, summary, cover } = Astro.props as Props;
const resolvedTitle = normalizeText(title) || UNTITLED_PROJECT;
const resolvedMedium = normalizeText(medium) || MEDIUM_PLACEHOLDER;
const resolvedSummary = normalizeText(summary) || SUMMARY_PLACEHOLDER;
const hasCover = Boolean(cover?.src);
---

<article class="group grid grid-cols-[1fr_248px_1fr] items-start gap-x-16">
  <div class="justify-self-end pt-5 text-right">
    <div class="font-accent text-[12px] uppercase tracking-[0.16em] text-ink/60">{resolvedMedium}</div>
  </div>

  <a href={href} class="focus-visible-outline block">
    <figure class="overflow-hidden border border-ink/12 bg-[#d9d9d9] transition-transform duration-300 group-hover:-translate-y-1">
      {hasCover ? (
        <img class="h-[164px] w-full object-cover grayscale-[0.1]" src={cover!.src} alt={cover!.alt} loading="lazy" />
      ) : (
        <div class="flex h-[164px] w-full items-center justify-center text-[10px] uppercase tracking-[0.18em] text-ink/45">
          {COVER_PLACEHOLDER}
        </div>
      )}
    </figure>
  </a>

  <div class="pt-5">
    <a href={href} class="focus-visible-outline inline-block">
      <h2 class="max-w-[14ch] text-[28px] font-semibold uppercase leading-[0.95] tracking-[-0.035em] transition-colors group-hover:text-accent">
        {resolvedTitle}
      </h2>
    </a>
    <p class="mt-3 max-w-[34ch] text-[13px] leading-[1.55] text-ink/82">{resolvedSummary}</p>
  </div>
</article>
