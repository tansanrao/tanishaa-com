---
import type { WorkMedia } from '../../lib/work';
import MediaGallery from './MediaGallery.astro';

interface Props {
  gallery: WorkMedia[];
  title: string;
}

const { gallery, title } = Astro.props as Props;
---

<MediaGallery
  gallery={gallery}
  title={title}
  layout="filmstrip"
  stageAspect="3 / 2"
  thumbAspect="3 / 2"
  itemAspect="3 / 2"
  showInlineCaption={true}
  showInlineControls={true}
  showFullscreenButton={true}
/>
